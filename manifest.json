{
  "Name": "Stream Dock Sonar",
  "Description": "Control SteelSeries GG Sonar mixer volume and mute directly.",
  "Author": "local",
  "Version": "0.3.0",
  "SDKVersion": 1,
  "CodePathWin": "plugin/StreamDockSonar.exe",
  "Icon": "icons/plugin",
  "CategoryIcon": "icons/plugin",
  "Category": "GG-Sonar",
  "PropertyInspectorPath": "property-inspector.html",
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Software": {
    "MinimumVersion": "3.10.188.226"
  },
  "Actions": [
    {
      "UUID": "local.streamdock.sonar.volume",
      "Name": "Sonar Mixer Volume",
      "Tooltip": "Adjust a SteelSeries Sonar mixer channel directly.",
      "Controllers": ["Keypad", "Knob"],
      "Icon": "icons/plugin",
      "States": [{ "Title": "Volume", "Image": "icons/plugin" }],
      "PropertyInspectorPath": "property-inspector.html"
    },
    {
      "UUID": "local.streamdock.sonar.mute",
      "Name": "Sonar Mixer Mute",
      "Tooltip": "Toggle mute for a SteelSeries Sonar mixer channel directly.",
      "Controllers": ["Keypad"],
      "Icon": "icons/plugin",
      "States": [
        { "Title": "Mute", "Image": "icons/plugin" },
        { "Title": "Muted", "Image": "icons/plugin" }
      ],
      "PropertyInspectorPath": "property-inspector.html"
    },
    {
      "UUID": "local.streamdock.sonar.overview",
      "Name": "Sonar Mixer Overview",
      "Tooltip": "Show selected SteelSeries Sonar mixer channel states.",
      "Controllers": ["Keypad"],
      "Icon": "icons/plugin",
      "States": [{ "Title": "Overview", "Image": "icons/plugin" }],
      "PropertyInspectorPath": "property-inspector.html"
    },
    {
      "UUID": "local.streamdock.sonar.chatmix",
      "Name": "Sonar ChatMix",
      "Tooltip": "Adjust SteelSeries Sonar ChatMix.",
      "Controllers": ["Keypad"],
      "Icon": "icons/plugin",
      "States": [{ "Title": "ChatMix", "Image": "icons/plugin" }],
      "PropertyInspectorPath": "property-inspector.html"
    },
    {
      "UUID": "local.streamdock.sonar.diagnostics",
      "Name": "Diagnostics",
      "Tooltip": "Show Sonar discovery and request diagnostics.",
      "Controllers": ["Keypad"],
      "Icon": "icons/plugin",
      "States": [{ "Title": "Diag", "Image": "icons/plugin" }],
      "PropertyInspectorPath": "property-inspector.html"
    }
  ]
}
