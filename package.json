{
  "name": "streamdock-sonar",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "check": "node --check property-inspector.js && node --check scripts/package-plugin.js && node -e \"JSON.parse(require('fs').readFileSync('manifest.json','utf8'))\"",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "install:local": "powershell -ExecutionPolicy Bypass -File scripts/install-local.ps1",
    "package": "npm run check && node scripts/package-plugin.js",
    "release:zip": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1",
    "release:zip:windows-docker": "powershell -ExecutionPolicy Bypass -File scripts/build-release-in-windows-docker.ps1",
    "build:plugin": "dotnet build plugin-csharp/StreamDockSonar.csproj -p:EnableWindowsTargeting=true"
  }
}
