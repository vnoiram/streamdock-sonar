<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>StreamDockSonar</AssemblyName>
    <RootNamespace>StreamDockSonar</RootNamespace>
    <StreamDockSdkRoot Condition="'$(StreamDockSdkRoot)' == ''">..\..\StreamDockSDK</StreamDockSdkRoot>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(StreamDockSdkRoot)\StreamDockSDK\StreamDockSDK.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\log4net.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>log4net.config</Link>
    </Content>
  </ItemGroup>

</Project>
